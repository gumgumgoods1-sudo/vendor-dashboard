rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This app has no login — every reader/writer is trusted equally. The only two
    // protections are (a) keeping your GitHub Pages URL unlisted and (b) these rules,
    // which restrict access to exactly the one document the app uses and nothing else.
    match /dashboards/main {
      allow read, write: if true;
    }
    // Everything else in this Firestore project is denied by default (no rule = no
    // access), so even if someone finds your firebaseConfig they can't read or write
    // any other collection/document.
  }
}
